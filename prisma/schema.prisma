// -----------------------------
// schema.prisma - Plateforme E-Learning Gamifiée
// -----------------------------

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//
// ENUMS
//

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum ModuleType {
  FREE
  GOLD
  DIAMOND
}

enum Currency {
  COINS
  DIAMONDS
  MONEY
}

// -----------------------------
// Utilisateurs
// -----------------------------
model User {
  id           String        @id @default(uuid())
  email        String        @unique
  name         String?
  role         Role
  password     String?
  wallet       Wallet?
  courses      Course[]      @relation("TeacherCourses")
  enrollments  Enrollment[]
  purchases    Purchase[]
  chatMessages ChatMessage[]
  createdAt    DateTime      @default(now())
}

// -----------------------------
// Wallet virtuel
// -----------------------------
model Wallet {
  id       String @id @default(uuid())
  user     User   @relation(fields: [userId], references: [id])
  userId   String @unique
  coins    Int    @default(0)
  diamonds Int    @default(0)
}

// -----------------------------
// Cours
// -----------------------------
model Course {
  id          String       @id @default(uuid())
  title       String
  description String?
  teacherId   String
  teacher     User         @relation("TeacherCourses", fields: [teacherId], references: [id])
  pdfModules  PDFModule[]
  enrollments Enrollment[]
  createdAt   DateTime     @default(now())
}

// -----------------------------
// Modules PDF
// -----------------------------
model PDFModule {
  id        String     @id @default(uuid())
  title     String
  type      ModuleType
  content   String
  summary   String?
  courseId  String
  course    Course     @relation(fields: [courseId], references: [id])
  purchases Purchase[]
}

// -----------------------------
// Inscriptions aux cours
// -----------------------------
model Enrollment {
  id           String        @id @default(uuid())
  userId       String
  courseId     String
  user         User          @relation(fields: [userId], references: [id])
  course       Course        @relation(fields: [courseId], references: [id])
  progress     Int           @default(0)
  quizAttempts QuizAttempt[]
}

// -----------------------------
// Historique des achats
// -----------------------------
model Purchase {
  id        String    @id @default(uuid())
  userId    String
  pdfId     String
  user      User      @relation(fields: [userId], references: [id])
  pdfModule PDFModule @relation(fields: [pdfId], references: [id])
  amount    Int
  currency  Currency
  createdAt DateTime  @default(now())
}

// -----------------------------
// Tentatives de quiz
// -----------------------------
model QuizAttempt {
  id           String      @id @default(uuid())
  enrollmentId String
  enrollment   Enrollment  @relation(fields: [enrollmentId], references: [id])
  questions    Json
  score        Int
  createdAt    DateTime    @default(now())
}

// -----------------------------
// Messages du chatbot IA
// -----------------------------
model ChatMessage {
  id        String   @id @default(uuid())
  userId    String
  content   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}